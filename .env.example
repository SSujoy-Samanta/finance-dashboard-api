# ---------------------------------------------------------
# Finance Dashboard API Environment Configuration
# ---------------------------------------------------------

# Server
NODE_ENV=development             # development | production | test
PORT=3000                        # Application port
TRUST_PROXY=0                    # Set to 1 if behind a reverse proxy (Railway, Render)
LOG_LEVEL=debug                  # debug | info | warn | error | silent

# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_dashboard

# JWT Security
# Generate secrets with: openssl rand -base64 64
JWT_ACCESS_SECRET=your_super_secret_access_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# Token Expiration (Standard JWT formats: 15m, 7d, 1h)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
CORS_ORIGIN=http://localhost:3000 # Allowed frontend origin

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes window
RATE_LIMIT_MAX=100              # Max requests per window per IP
